# Copy to .env and adjust values before running the Registry server locally.
#
# SQLite file path relative to repo root unless you pass an absolute path.
# Examples: sqlite:///data/registry.db  |  sqlite:///C:/app/registry.db

REGISTRY_DATABASE_URL=sqlite:///data/registry.db

REGISTRY_HOST=127.0.0.1
REGISTRY_PORT=8080

# Bearer token required for POST/PUT/DELETE on Registry write routes.
# Generate a random string for local development; production must use a strong secret.

REGISTRY_WRITE_TOKEN=change_me_generate_a_random_secret

# Base URL matching host/port above — used when something other than SQLite needs the API URL
# (e.g. demos or tooling that call REST by URL).

REGISTRY_API_URL=http://127.0.0.1:8080

# Optional. JSON map: agent id -> bearer token for directory/catalog requests that expose
# data scoped to an authenticated buyer. Leave empty {} if unused.

REGISTRY_AGENT_TOKENS={"demo-buyer":"change_me_optional_per_agent_token"}
